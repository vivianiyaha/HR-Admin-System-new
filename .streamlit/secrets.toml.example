# .streamlit/secrets.toml
# ─────────────────────────────────────────────────────────────────────────────
# DO NOT commit this file with real secrets.
# Add secrets.toml to .gitignore, and use Streamlit Cloud's Secrets manager
# or environment variables in production.
# ─────────────────────────────────────────────────────────────────────────────

# App security
PASSWORD_SALT = "cardstel_hr_salt_2026"
SESSION_TIMEOUT_MINUTES = "480"   # 8 hours

# User accounts JSON (override users.json with env variable)
# USER_ACCOUNTS = '{"admin":{"password_hash":"...","role":"admin","name":"Admin","email":"admin@cardstel.com"}}'

# Sub-app URLs (when running as separate Streamlit apps)
ATTENDANCE_URL         = "https://staff-attendance.streamlit.app/"
BUSINESS_APPRAISAL_URL = "https://business-department.streamlit.app/"
STAFF_APPRAISAL_URL    = "https://staff-performance.streamlit.app/"
ADMIN_PANEL_URL        = "https://management-panel.streamlit.app/"
